@model IEnumerable<PokeCardMvc.Models.Pokemon>

@{
    ViewData["Title"] = "Voici la liste de vos Pokemon";
}

<h1>@ViewData["Title"]</h1>

<div class="row g-8">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-5">
            <div class="card- h-100 shadow border border-danger-2">
                <div class="text-center-p-3 d-flex justify-content-center p-3">
                    <img src="@item.Image" alt="@item.Name" style="width: 200px">
                </div>
                <div class="card-body text-center">
                    <h5 class="card-title text-capitalize">@item.Id - @item.Name</h5>
                    <span class="badge bg-primary mb-2">@item.Type</span>
                </div>
                <div class="d-flex justify-content-around mt-2">
                    <small>H: @(item.Height / 10)m</small>
                    <small>W: @(item.Weight / 10)kg</small>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-around mt-1">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Modifier</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-success">Details</a>
            </div>
        </div>
    }
</div>

