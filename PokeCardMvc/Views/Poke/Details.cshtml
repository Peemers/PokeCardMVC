@model PokeCardMvc.Models.Pokemon

@{
    ViewData["Title"] = "Fiche de " + Model.Name;
}

<div class="container mt-0"></div>
    <div class="card shadow-lg border-2 overflow-hidden">
        <div class="row-g-0">
            <div class="col-md4 bg-light d-flex align-items-center justify-content-center p-4">
                <img src="@Model.Image" alt="@Model.Name" class="img-fluid" style="transform: scale(4);">
            </div>
            
            <div class=col-md-8>
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h1 class="display-4 fw-bold">@Model.Name</h1>
                            <span class="badge rounded-pill bg-primary fs-5">@Model.Type</span>
                        </div>
                        <h2 class="text-muted">@Model.Id</h2>
                    </div>
                    <hr class="my-4">
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <h5 class="text-muted">Physique</h5>
                            <p class="fs-4"><strong>Taille :</strong> @(Model.Height / 10)m </p>
                            <p class="fs-4"><strong>Poids :</strong> @(Model.Weight/ 10)kg </p>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-lg">Modifier</a>
                        <a asp-action="Index" class="btn btn-outline-dark btn-lg">Retour à la Liste</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
